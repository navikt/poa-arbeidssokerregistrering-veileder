        "format:app": "biome check --write src"
    },
    "dependencies": {
        "@grafana/faro-web-sdk": "2.2.0",
        "@navikt/aksel-icons": "8.10.2",
        "@navikt/arbeidssokerregisteret-utils": "2.1.0",
        "@navikt/ds-css": "8.10.2",
        "@navikt/ds-react": "8.10.2",
        "@navikt/ds-tailwind": "8.10.2",
        "@navikt/next-logger": "4.4.4",
        "@navikt/oasis": "4.1.4",
        "@unleash/nextjs": "1.6.4",
        "loadjs": "4.3.0",
        "nanoid": "5.1.9",
        "next": "16.2.4",
        "pino": "10.3.1",
        "react": "19.2.4",
        "react-dom": "19.2.4"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.13",
        "@chromatic-com/storybook": "5.1.2",
        "@storybook/addon-docs": "10.3.5",
        "@storybook/addon-onboarding": "10.3.5",
        "@storybook/nextjs": "10.3.5",
        "@storybook/nextjs-vite": "10.3.5",
        "@tailwindcss/postcss": "4.2.4",
        "@testing-library/react": "16.3.2",
        "@types/node": "25.6.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "husky": "9.1.7",
        "jsdom": "29.0.2",
        "knip": "5.82.1",
        "lint-staged": "16.4.0",
        "msw": "2.12.14",
        "msw-storybook-addon": "2.0.7",
        "pino-pretty": "13.1.3",
        "postcss": "8.5.12",
        "storybook": "10.3.5",
        "tailwindcss": "4.2.4",
        "typescript": "5.9.3",
        "vitest": "4.1.5"
    },
    "lint-staged": {
        "src/app/**/*.{js,jsx,json,ts,tsx}": "biome check --write"

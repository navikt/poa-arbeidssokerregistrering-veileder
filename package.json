{
    "name": "poa-arbeidssokerregistrering-veileder",
    "version": "1.0.0",
    "private": true,
     "packageManager": "pnpm@11.9.0",
    "scripts": {
        "dev": "next dev | pino-pretty",
        "build": "next build",
        "start": "next start",
        "lint": "biome check",
        "test": "vitest --run",
        "test:watch": "vitest",
        "test:ci": "vitest --run",
        "refresh": "rm -rf node_modules && rm pnpm-lock.yaml && pnpm install --ignore-scripts",
        "prepare": "husky",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "format:app": "biome check --write src"
    },
    "dependencies": {
        "@grafana/faro-web-sdk": "2.8.0",
        "@navikt/aksel-icons": "8.15.0",
        "@navikt/arbeidssokerregisteret-utils": "2.1.0",
        "@navikt/ds-css": "8.15.0",
        "@navikt/ds-react": "8.15.0",
        "@navikt/ds-tailwind": "8.15.0",
        "@navikt/next-logger": "5.0.0",
        "@navikt/oasis": "4.1.4",
        "@unleash/nextjs": "1.6.7",
        "nanoid": "5.1.16",
        "next": "16.2.9",
        "pino": "10.3.1",
        "react": "19.2.7",
        "react-dom": "19.2.7"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.1",
        "@chromatic-com/storybook": "5.2.1",
        "@storybook/addon-docs": "10.4.6",
        "@storybook/addon-onboarding": "10.4.6",
        "@storybook/nextjs": "10.4.6",
        "@storybook/nextjs-vite": "10.4.6",
        "@tailwindcss/postcss": "4.3.2",
        "@testing-library/react": "16.3.2",
        "@types/node": "25.9.3",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "husky": "9.1.7",
        "jsdom": "29.1.1",
        "knip": "6.23.0",
        "lint-staged": "17.0.8",
        "msw": "2.14.6",
        "msw-storybook-addon": "2.0.7",
        "pino-pretty": "13.1.3",
        "postcss": "8.5.16",
        "storybook": "10.4.6",
        "tailwindcss": "4.3.2",
        "typescript": "6.0.3",
        "vitest": "4.1.9"
    },
    "lint-staged": {
        "src/app/**/*.{js,jsx,json,ts,tsx}": "biome check --write"
    },
    "engines": {
        "node": ">=24.18.0"
    },
    "msw": {
        "workerDirectory": [
            "public"
        ]
    }
}
